    "To skip the passphrase prompt at every reboot, add `--apple-use-keychain` to cache it in macOS Keychain." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um die Passphrase-Abfrage bei jedem Neustart zu überspringen, füge `--apple-use-keychain` hinzu, um sie im macOS-Schlüsselbund zu cachen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
