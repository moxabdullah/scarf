    "This removes the credential from hermes. The upstream provider key is not revoked." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Damit werden die Anmeldedaten aus hermes entfernt. Der Schlüssel beim Upstream-Anbieter wird nicht widerrufen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto quita la credencial de hermes. La clave del proveedor original no se revoca."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela retire les identifiants de hermes. La clé chez le fournisseur amont n'est pas révoquée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
