        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎回の再起動時にパスフレーズのプロンプトをスキップするには、`--apple-use-keychain` を追加して macOS キーチェーンにキャッシュしてください。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
